{
  "name": "rusvel-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write \"src/**/*.{svelte,ts,js,css}\"",
    "format:check": "prettier --check \"src/**/*.{svelte,ts,js,css}\"",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:visual": "playwright test --project=visual",
    "test:analyze": "node --loader ts-node/esm tests/analyze-visual.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/svelte": "^1.5.1",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "driver.js": "^1.4.0",
    "layerchart": "^1.0.13",
    "lucide-svelte": "^0.577.0",
    "svelte-confetti": "^2.3.2",
    "svelte-copy": "^2.0.0",
    "svelte-sonner": "^1.1.0",
    "svelte-streamdown": "^3.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2"
  }
}
